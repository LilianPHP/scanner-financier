# =====================================================
# Scanner Financier — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# =====================================================

# Supabase (récupérer sur supabase.com → Settings → API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Claude API (pour catégorisation IA optionnelle)
ANTHROPIC_API_KEY=sk-ant-...

# Powens Open Banking
POWENS_DOMAIN=senzio-sandbox
POWENS_CLIENT_ID=your-powens-client-id
POWENS_CLIENT_SECRET=your-powens-client-secret

# URLs
FRONTEND_URL=https://scanner-financier.vercel.app
BACKEND_URL=https://ton-backend.railway.app
